# Copier ce fichier vers .env et remplir les valeurs
PORT=5000
NODE_ENV=development

# Chaîne de connexion MongoDB (locale ou MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/ecommerce

# Secret pour signer les JWT (générer une longue chaîne aléatoire)
JWT_SECRET=change_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Clé secrète Stripe (mode test : sk_test_...)
STRIPE_SECRET_KEY=

# URL du frontend autorisée par CORS
CLIENT_URL=http://localhost:5173
